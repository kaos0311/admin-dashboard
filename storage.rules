rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    /*
    |--------------------------------------------------------------------------
    | AUTH HELPERS
    |--------------------------------------------------------------------------
    */

    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function userDocExists() {
      return signedIn() &&
        firestore.exists(userDocPath());
    }

    function userDoc() {
      return firestore.get(userDocPath()).data;
    }

    function userIsActive() {
      return userDocExists() &&
        userDoc().active == true;
    }

    function roleFromToken(role) {
      return signedIn() &&
        request.auth.token.role is string &&
        request.auth.token.role == role;
    }

    function roleFromUserDoc(role) {
      return userDocExists() &&
        userDoc().role is string &&
        userDoc().role == role;
    }

    function hasRole(role) {
      return roleFromToken(role) ||
        roleFromUserDoc(role);
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isStaff() {
      return hasRole("staff");
    }

    function isStaffOrAdmin() {
      return isAdmin() || isStaff();
    }

    function canAccessDashboard() {
      return signedIn() &&
        isStaffOrAdmin() &&
        userIsActive();
    }

    function canAdminWrite() {
      return signedIn() &&
        isAdmin() &&
        userIsActive();
    }

    /*
    |--------------------------------------------------------------------------
    | FILE VALIDATION
    |--------------------------------------------------------------------------
    */

    function hasIncomingFile() {
      return request.resource != null;
    }

    function isPdf() {
      return hasIncomingFile() &&
        request.resource.contentType == "application/pdf";
    }

    function isCsv() {
      return hasIncomingFile() &&
        (
          request.resource.contentType == "text/csv" ||
          request.resource.contentType == "application/csv" ||
          request.resource.contentType == "application/vnd.ms-excel" ||
          request.resource.contentType.matches(".*csv.*")
        );
    }

    function isReportSizeAllowed() {
      return hasIncomingFile() &&
        request.resource.size > 0 &&
        request.resource.size <= 50 * 1024 * 1024;
    }

    function isPatientDocumentSizeAllowed() {
      return hasIncomingFile() &&
        request.resource.size > 0 &&
        request.resource.size <= 25 * 1024 * 1024;
    }

    /*
    |--------------------------------------------------------------------------
    | REPORT UPLOADS
    |--------------------------------------------------------------------------
    |
    | CSV and PDF imports for Brightree/server report processing.
    |
    */

    match /reports/{allPaths=**} {
      allow read:
        if canAccessDashboard();

      allow create, update:
        if canAccessDashboard() &&
        isReportSizeAllowed() &&
        (isCsv() || isPdf());

      allow delete:
        if canAdminWrite();
    }

    /*
    |--------------------------------------------------------------------------
    | LEGACY IMPORTS
    |--------------------------------------------------------------------------
    |
    | Kept for older CSV-only import paths.
    |
    */

    match /imports/{allPaths=**} {
      allow read:
        if canAccessDashboard();

      allow create, update:
        if canAccessDashboard() &&
        isReportSizeAllowed() &&
        isCsv();

      allow delete:
        if canAdminWrite();
    }

    /*
    |--------------------------------------------------------------------------
    | PATIENT DOCUMENTS
    |--------------------------------------------------------------------------
    |
    | Signed tickets, orders, CMNs, PARs, prescriptions, and insurance docs.
    |
    */

    match /patient-documents/{patientId}/{allPaths=**} {
      allow read:
        if canAccessDashboard();

      allow create, update:
        if canAccessDashboard() &&
        isPatientDocumentSizeAllowed() &&
        isPdf();

      allow delete:
        if canAdminWrite();
    }

    /*
    |--------------------------------------------------------------------------
    | LEGACY CAMELCASE PATIENT DOCUMENT PATH
    |--------------------------------------------------------------------------
    */

    match /patientDocuments/{patientId}/{allPaths=**} {
      allow read:
        if canAccessDashboard();

      allow create, update:
        if canAccessDashboard() &&
        isPatientDocumentSizeAllowed() &&
        isPdf();

      allow delete:
        if canAdminWrite();
    }

    /*
    |--------------------------------------------------------------------------
    | DENY EVERYTHING ELSE
    |--------------------------------------------------------------------------
    */

    match /{allPaths=**} {
      allow read, write:
        if false;
    }
  }
}